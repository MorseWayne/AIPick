# 默认大模型(如果你用 Claude 则自己调整对应的 SDK 或换名字)
OPENAI_API_KEY=sk-your-llm-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Phase 1 深度搜索模型（可选，使用 DashScope 原生 SDK 调用）
# 设置为 qwen-deep-research 启用深度搜索能力，留空则回退到 LLM_MODEL + enable_search
# RESEARCH_MODEL=qwen-deep-research

# MCP服务器地址 (如果在测试时需要不同地址可自行提取到 config)
XHS_MCP_URL=http://10.10.131.118:18060/mcp
